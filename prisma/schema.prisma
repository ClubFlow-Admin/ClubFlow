generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  draft
  reviewed
  published
}

enum NewsletterFrequency {
  daily
  weekly
}

enum EntityStatus {
  active
  inactive
}

enum FeedAvailability {
  available
  unavailable
  manual
}

enum IntakeStatus {
  pending
  approved
  rejected
  archived
  scheduled
}

enum ImportRunStatus {
  ok
  error
}

model Article {
  id                String        @id @default(cuid())
  title             String
  dek               String?
  slug              String        @unique
  originalUrl       String        @unique
  author            String?
  publishedAt       DateTime
  tags              String[]      @default([])
  clubName          String?
  city              String?
  state             String?
  originalExcerpt   String?
  aiSummary         String
  aiWhatHappened    String?
  aiWhyItMatters    String?
  aiKeyTakeaways    String[]      @default([])
  aiIndustryContext String?
  importanceScore   Int           @default(50)
  status            ArticleStatus @default(draft)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  sourceId    String
  source      Source      @relation(fields: [sourceId], references: [id])
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  heroImageId String?
  heroImage   MediaAsset? @relation(fields: [heroImageId], references: [id], onDelete: SetNull)

  executiveMove        ExecutiveMove?
  developmentProject   DevelopmentProject?
  newsletterStories    NewsletterStory[]
  intakeApprovedFrom   IntakeItem?         @relation("IntakeApprovedArticle")
  duplicateIntakeItems IntakeItem[]        @relation("IntakeDuplicateArticle")

  clubs     Club[]
  companies Company[]
  people    Person[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([sourceId])
  @@index([heroImageId])
  @@index([clubName])
  @@index([city, state])
}

model MediaAsset {
  id        String    @id @default(cuid())
  title     String
  url       String    @unique
  altText   String?
  caption   String?
  credit    String?
  category  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]

  @@index([category])
}

model Source {
  id                         String           @id @default(cuid())
  name                       String           @unique
  organization               String?
  homepageUrl                String?
  rssUrl                     String?
  sourceType                 String           @default("other")
  primaryCategory            String?
  categories                 String[]         @default([])
  priority                   Int              @default(50)
  active                     Boolean          @default(true)
  feedAvailability           FeedAvailability @default(available)
  importFrequencyMinutes     Int              @default(60)
  needsReview                Boolean          @default(false)
  reviewNote                 String?
  firstPartyFeedCandidateUrl String?
  firstPartyFeedCheckedAt    DateTime?
  lastCheckedAt              DateTime?
  lastSuccessfulImportAt     DateTime?
  notes                      String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  articles                   Article[]
  intakeItems                IntakeItem[]
  importRuns                 ImportRun[]

  @@index([active, sourceType])
  @@index([primaryCategory])
}

model IntakeItem {
  id                      String       @id @default(cuid())
  sourceId                String
  source                  Source       @relation(fields: [sourceId], references: [id])
  originalUrl             String       @unique
  title                   String
  publishedAt             DateTime
  rawExcerpt              String?
  rawContent              String?
  suggestedCategorySlug   String?
  suggestedTags           String[]     @default([])
  suggestedImportance     Int          @default(50)
  executiveSummary        String
  suggestedHeroImageUrl   String?
  originalPublisherName   String?
  duplicateConfidence     Int          @default(0)
  duplicateOfArticleId    String?
  duplicateOfArticle      Article?     @relation("IntakeDuplicateArticle", fields: [duplicateOfArticleId], references: [id], onDelete: SetNull)
  duplicateOfIntakeItemId String?
  duplicateOfIntakeItem   IntakeItem?  @relation("IntakeDuplicateItem", fields: [duplicateOfIntakeItemId], references: [id], onDelete: SetNull)
  duplicateCandidates     IntakeItem[] @relation("IntakeDuplicateItem")
  status                  IntakeStatus @default(pending)
  scheduledFor            DateTime?
  articleId               String?      @unique
  article                 Article?     @relation("IntakeApprovedArticle", fields: [articleId], references: [id], onDelete: SetNull)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@index([status, publishedAt])
  @@index([sourceId])
  @@index([duplicateOfArticleId])
}

model ImportRun {
  id                String          @id @default(cuid())
  sourceId          String
  source            Source          @relation(fields: [sourceId], references: [id])
  startedAt         DateTime        @default(now())
  finishedAt        DateTime?
  itemsFound        Int             @default(0)
  itemsCreated      Int             @default(0)
  duplicatesSkipped Int             @default(0)
  status            ImportRunStatus @default(ok)
  errorMessage      String?

  @@index([sourceId, startedAt])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  articles    Article[]
}

model NewsletterSubscriber {
  id        String              @id @default(cuid())
  email     String              @unique
  frequency NewsletterFrequency @default(weekly)
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model NewsletterIssue {
  id          String              @id @default(cuid())
  title       String
  frequency   NewsletterFrequency
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  stories     NewsletterStory[]
}

model NewsletterStory {
  id           String          @id @default(cuid())
  issueId      String
  articleId    String
  shortSummary String
  position     Int             @default(0)
  issue        NewsletterIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  article      Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([issueId, articleId])
}

model JobPosting {
  id          String        @id @default(cuid())
  title       String
  clubName    String
  city        String?
  state       String?
  url         String?
  postedAt    DateTime      @default(now())
  expiresAt   DateTime?
  description String?
  status      ArticleStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([title, clubName])
}

model ExecutiveMove {
  id           String        @id @default(cuid())
  executive    String
  newRole      String
  previousRole String?
  clubName     String
  city         String?
  state        String?
  effectiveAt  DateTime?
  publishedAt  DateTime?
  notes        String?
  status       ArticleStatus @default(draft)
  articleId    String?       @unique
  article      Article?      @relation(fields: [articleId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model DevelopmentProject {
  id          String   @id @default(cuid())
  clubName    String
  projectName String
  city        String?
  state       String?
  budget      String?
  timeline    String?
  architect   String?
  status      String?
  description String?
  articleId   String?  @unique
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RankingEntry {
  id          String        @id @default(cuid())
  category    String
  rank        Int
  clubName    String
  city        String?
  state       String?
  score       Int?
  rationale   String
  publishedAt DateTime?
  status      ArticleStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([category, clubName])
  @@index([category, rank])
}

model Club {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  location    String?
  city        String?
  state       String?
  country     String?
  clubType    String?
  website     String?
  logoUrl     String?
  description String?
  foundedYear Int?
  holes       Int?
  tags        String[]     @default([])
  status      EntityStatus @default(active)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  articles Article[]

  @@index([status])
  @@index([city, state])
}

model Company {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  industry     String?
  website      String?
  logoUrl      String?
  description  String?
  headquarters String?
  tags         String[]     @default([])
  status       EntityStatus @default(active)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  articles Article[]

  @@index([status])
  @@index([industry])
}

model Person {
  id                  String       @id @default(cuid())
  firstName           String
  lastName            String
  slug                String       @unique
  title               String?
  biography           String?
  photoUrl            String?
  linkedInUrl         String?
  currentOrganization String?
  tags                String[]     @default([])
  status              EntityStatus @default(active)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  articles Article[]

  @@index([status])
  @@index([lastName, firstName])
}

model PodcastEpisode {
  id          String        @id @default(cuid())
  showName    String
  title       String        @unique
  description String
  duration    String?
  publishedAt DateTime?
  audioUrl    String?
  comingSoon  Boolean       @default(true)
  status      ArticleStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
